<Application x:Class="GlassTodo.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:GlassTodo.Converters"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Palette.Dark.xaml" />
                <ResourceDictionary Source="Themes/Glass.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
            <conv:ZeroToVisibleConverter x:Key="ZeroToVisible" />
            <conv:NonZeroToVisibleConverter x:Key="NonZeroToVisible" />
            <conv:StringEmptyToVisibleConverter x:Key="StringEmptyToVis" />
            <conv:NonEmptyStringToVisibleConverter x:Key="NonEmptyStringToVis" />
            <conv:HexToBrushConverter x:Key="HexToBrush" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
