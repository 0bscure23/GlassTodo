<Window x:Class="GlassTodo.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GlassTodo.ViewModels"
        xmlns:models="clr-namespace:GlassTodo.Models"
        xmlns:views="clr-namespace:GlassTodo.Views"
        xmlns:b="clr-namespace:GlassTodo.Behaviors"
        Title="琉璃清单"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="{StaticResource AppFont}"
        FontSize="14"
        Foreground="{DynamicResource TextPrimaryBrush}"
        KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove"
        MouseEnter="Window_MouseEnter"
        MouseLeave="Window_MouseLeave">

    <Window.Resources>

        <!-- 快速添加区的优先级按钮：颜色随选中的优先级变化 -->
        <Style x:Key="ComposeFlagStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ComposePriority}" Value="{x:Static models:Priority.Low}">
                    <Setter Property="Foreground" Value="{DynamicResource PriorityLowBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ComposePriority}" Value="{x:Static models:Priority.Medium}">
                    <Setter Property="Foreground" Value="{DynamicResource PriorityMediumBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding ComposePriority}" Value="{x:Static models:Priority.High}">
                    <Setter Property="Foreground" Value="{DynamicResource PriorityHighBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ComposeDueStyle" TargetType="Button" BasedOn="{StaticResource SmallIconButton}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding ComposeHasSchedule}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource AccentBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- 日期选择弹层里的小胶囊按钮 -->
        <Style x:Key="PickerChipButton" TargetType="Button" BasedOn="{StaticResource SubtleButton}">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <!-- ===== 任务行模板 ===== -->
        <DataTemplate x:Key="TaskRowTemplate" DataType="{x:Type vm:TaskItemViewModel}">
            <Border x:Name="Row" Background="{DynamicResource CardFillBrush}" CornerRadius="10"
                    Margin="0,3" MinHeight="44" RenderTransformOrigin="0.5,0.5"
                    MouseLeftButtonDown="Row_MouseLeftButtonDown">
                <Border.LayoutTransform>
                    <ScaleTransform ScaleY="1" />
                </Border.LayoutTransform>
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform />
                        <TranslateTransform Y="0" />
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <!-- 液态模式：悬停果冻般微胀 -->
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                    <Condition Binding="{Binding DataContext.IsLiquidStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                </MultiDataTrigger.Conditions>
                                <MultiDataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                             To="1.016" Duration="0:0:0.24">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase Amplitude="0.9" EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                             To="1.016" Duration="0:0:0.24">
                                                <DoubleAnimation.EasingFunction>
                                                    <BackEase Amplitude="0.9" EasingMode="EaseOut" />
                                                </DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.EnterActions>
                                <MultiDataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.16" />
                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.16" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </MultiDataTrigger.ExitActions>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid Margin="10,7">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border x:Name="PriorityStripe" Width="3" CornerRadius="2" Margin="0,3,9,3"
                            Visibility="Collapsed" />

                    <ToggleButton Grid.Column="1" Style="{StaticResource GlassCheck}"
                                  IsChecked="{Binding IsDone, Mode=TwoWay}"
                                  VerticalAlignment="Center" Margin="0,0,10,0" />

                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                        <Grid>
                            <TextBlock x:Name="TitleText" Text="{Binding Title}" FontSize="14"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}" />
                            <TextBox Style="{StaticResource InlineEditBox}"
                                     Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                     Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                     b:ViewBehaviors.FocusWhenVisible="True"
                                     b:ViewBehaviors.IsEditBox="True"
                                     KeyDown="RowEdit_KeyDown" LostFocus="RowEdit_LostFocus" />
                        </Grid>
                        <StackPanel Orientation="Horizontal" Margin="0,3,0,0"
                                    Visibility="{Binding HasMeta, Converter={StaticResource BoolToVis}}">
                            <Ellipse Width="6" Height="6" Margin="0,1,6,0" VerticalAlignment="Center"
                                     Fill="{Binding ListColorHex, Converter={StaticResource HexToBrush}}"
                                     Visibility="{Binding ShowListDot, Converter={StaticResource BoolToVis}}" />
                            <TextBlock x:Name="DueTextBlock" Text="{Binding DueText}" FontSize="11.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding HasDue, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="&#xE823;" FontFamily="{StaticResource FluentIcons}" FontSize="10"
                                       Margin="8,2,3,0" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding HasReminder, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding RemindTimeText}" FontSize="11.5"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Visibility="{Binding HasReminder, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </StackPanel>

                    <StackPanel x:Name="Actions" Grid.Column="3" Orientation="Horizontal"
                                VerticalAlignment="Center" Opacity="0">
                        <Button x:Name="FlagBtn" Style="{StaticResource SmallIconButton}" Content="&#xE7C1;"
                                ToolTip="优先级" Command="{Binding CyclePriorityCommand}" />
                        <Button Style="{StaticResource SmallIconButton}" Content="&#xE787;"
                                ToolTip="日期与提醒" Click="RowDue_Click" />
                        <Button Style="{StaticResource SmallIconButton}" Content="&#xE74D;"
                                ToolTip="删除" Command="{Binding DeleteCommand}" />
                    </StackPanel>
                </Grid>
            </Border>

            <DataTemplate.Triggers>
                <Trigger SourceName="Row" Property="IsMouseOver" Value="True">
                    <Setter TargetName="Row" Property="Background" Value="{DynamicResource CardFillHoverBrush}" />
                    <Setter TargetName="Actions" Property="Opacity" Value="1" />
                </Trigger>

                <DataTrigger Binding="{Binding IsDone}" Value="True">
                    <Setter TargetName="TitleText" Property="Foreground" Value="{DynamicResource TextDoneBrush}" />
                    <Setter TargetName="TitleText" Property="TextDecorations" Value="Strikethrough" />
                </DataTrigger>

                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                    <Setter TargetName="DueTextBlock" Property="Foreground" Value="{DynamicResource DangerBrush}" />
                </DataTrigger>

                <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:Priority.Low}">
                    <Setter TargetName="PriorityStripe" Property="Visibility" Value="Visible" />
                    <Setter TargetName="PriorityStripe" Property="Background" Value="{DynamicResource PriorityLowBrush}" />
                    <Setter TargetName="FlagBtn" Property="Foreground" Value="{DynamicResource PriorityLowBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:Priority.Medium}">
                    <Setter TargetName="PriorityStripe" Property="Visibility" Value="Visible" />
                    <Setter TargetName="PriorityStripe" Property="Background" Value="{DynamicResource PriorityMediumBrush}" />
                    <Setter TargetName="FlagBtn" Property="Foreground" Value="{DynamicResource PriorityMediumBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding Priority}" Value="{x:Static models:Priority.High}">
                    <Setter TargetName="PriorityStripe" Property="Visibility" Value="Visible" />
                    <Setter TargetName="PriorityStripe" Property="Background" Value="{DynamicResource PriorityHighBrush}" />
                    <Setter TargetName="FlagBtn" Property="Foreground" Value="{DynamicResource PriorityHighBrush}" />
                </DataTrigger>

                <DataTrigger Binding="{Binding IsLeaving}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="Row" Storyboard.TargetProperty="Opacity"
                                                 To="0" Duration="0:0:0.18" />
                                <DoubleAnimation Storyboard.TargetName="Row"
                                                 Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)"
                                                 To="0" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <QuadraticEase EasingMode="EaseIn" />
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetName="Row" Storyboard.TargetProperty="Opacity"
                                                 To="1" Duration="0:0:0.01" />
                                <DoubleAnimation Storyboard.TargetName="Row"
                                                 Storyboard.TargetProperty="(FrameworkElement.LayoutTransform).(ScaleTransform.ScaleY)"
                                                 To="1" Duration="0:0:0.01" />
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.ExitActions>
                </DataTrigger>

                <EventTrigger RoutedEvent="FrameworkElement.Loaded" SourceName="Row">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="Row" Storyboard.TargetProperty="Opacity"
                                             From="0" To="1" Duration="0:0:0.2" />
                            <DoubleAnimation Storyboard.TargetName="Row"
                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                             From="-8" To="0" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut" />
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid Margin="22">
        <!-- 玻璃层叠（分层窗口逐像素透明）：清玻璃底 → 镜面高光 → 液态光层 → 棱边 → 内容 -->
        <Border x:Name="CardRoot" CornerRadius="18" Background="{DynamicResource GlassTintBrush}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="28" ShadowDepth="10" Direction="270" Opacity="0.38" Color="#000000" />
            </Border.Effect>
        </Border>
        <Border Background="{DynamicResource SpecularBrush}" CornerRadius="18" IsHitTestVisible="False" />

        <!-- 液态玻璃层：跟随鼠标的柔光斑 + 锐利光点 + 呼出时的光带扫过（仅液态模式可见） -->
        <Border x:Name="LiquidLight" CornerRadius="18" IsHitTestVisible="False" Visibility="Collapsed" Opacity="0">
            <Border.Background>
                <RadialGradientBrush x:Name="LiquidLightBrush" MappingMode="Absolute"
                                     RadiusX="170" RadiusY="170" Center="190,220" GradientOrigin="190,220">
                    <GradientStop Color="{DynamicResource LiquidLightColor}" Offset="0" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        <Border x:Name="LiquidGlint" CornerRadius="18" IsHitTestVisible="False" Visibility="Collapsed" Opacity="0">
            <Border.Background>
                <RadialGradientBrush x:Name="LiquidGlintBrush" MappingMode="Absolute"
                                     RadiusX="46" RadiusY="46" Center="190,220" GradientOrigin="190,220">
                    <GradientStop Color="{DynamicResource LiquidGlintColor}" Offset="0" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </RadialGradientBrush>
            </Border.Background>
        </Border>
        <Border x:Name="SheenSweep" Width="130" HorizontalAlignment="Left" IsHitTestVisible="False" Opacity="0">
            <Border.RenderTransform>
                <TranslateTransform x:Name="SheenT" X="-160" />
            </Border.RenderTransform>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.25">
                    <GradientStop Color="#00FFFFFF" Offset="0" />
                    <GradientStop Color="{DynamicResource LiquidSheenColor}" Offset="0.5" />
                    <GradientStop Color="#00FFFFFF" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Border BorderBrush="{DynamicResource WindowInnerStrokeBrush}" BorderThickness="1"
                CornerRadius="18" IsHitTestVisible="False" />
        <Border x:Name="LiquidRim" BorderBrush="{DynamicResource LiquidRimBrush}" BorderThickness="1.4"
                CornerRadius="18" IsHitTestVisible="False" Visibility="Collapsed" />
        <Border Height="1" VerticalAlignment="Top" Margin="26,1,26,0"
                Background="{DynamicResource HairlineTopBrush}" IsHitTestVisible="False" />

        <Grid x:Name="ContentRoot" Margin="14,12,14,14">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 头部 -->
            <Grid Grid.Row="0" Margin="4,2,0,10">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="琉璃清单" FontSize="16" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TodayText}" FontSize="11.5"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="10,4,0,0" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ToggleButton Style="{StaticResource PinToggle}" IsChecked="{Binding IsPinned, Mode=TwoWay}"
                                  ToolTip="固定面板（不再自动隐藏）" />
                    <Button Style="{StaticResource IconButton}" Content="&#xE713;" ToolTip="设置"
                            Click="SettingsButton_Click" Margin="2,0,0,0" />
                </StackPanel>
            </Grid>

            <!-- 清单 chips -->
            <ScrollViewer x:Name="ChipsScroll" Grid.Row="1" Margin="0,0,0,10"
                          HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled"
                          PreviewMouseWheel="ChipsScroll_PreviewMouseWheel">
                <ItemsControl ItemsSource="{Binding Chips}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:ChipViewModel}">
                            <Grid Margin="0,0,6,0" MouseRightButtonUp="Chip_MouseRightButtonUp">
                                <Button Click="Chip_Click" Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVis}}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Pill" Background="{DynamicResource CardFillBrush}"
                                                    CornerRadius="999" Padding="11,5"
                                                    RenderTransformOrigin="0.5,0.5">
                                                <Border.RenderTransform>
                                                    <ScaleTransform />
                                                </Border.RenderTransform>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <MultiDataTrigger>
                                                                <MultiDataTrigger.Conditions>
                                                                    <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                                    <Condition Binding="{Binding DataContext.IsLiquidStyle, RelativeSource={RelativeSource AncestorType=Window}}" Value="True" />
                                                                </MultiDataTrigger.Conditions>
                                                                <MultiDataTrigger.EnterActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                             To="1.07" Duration="0:0:0.22">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <BackEase Amplitude="1" EasingMode="EaseOut" />
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                             To="1.07" Duration="0:0:0.22">
                                                                                <DoubleAnimation.EasingFunction>
                                                                                    <BackEase Amplitude="1" EasingMode="EaseOut" />
                                                                                </DoubleAnimation.EasingFunction>
                                                                            </DoubleAnimation>
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </MultiDataTrigger.EnterActions>
                                                                <MultiDataTrigger.ExitActions>
                                                                    <BeginStoryboard>
                                                                        <Storyboard>
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                                             To="1" Duration="0:0:0.15" />
                                                                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                                             To="1" Duration="0:0:0.15" />
                                                                        </Storyboard>
                                                                    </BeginStoryboard>
                                                                </MultiDataTrigger.ExitActions>
                                                            </MultiDataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="AddGlyph" Text="&#xE710;"
                                                               FontFamily="{StaticResource FluentIcons}" FontSize="11"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               Visibility="Collapsed" />
                                                    <TextBlock x:Name="Label" Text="{Binding Name}" FontSize="12"
                                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                                               VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Pill" Property="Background"
                                                            Value="{DynamicResource CardFillHoverBrush}" />
                                                    <Setter TargetName="Label" Property="Foreground"
                                                            Value="{DynamicResource TextPrimaryBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="Pill" Property="Background"
                                                            Value="{DynamicResource AccentDimBrush}" />
                                                    <Setter TargetName="Label" Property="Foreground"
                                                            Value="{DynamicResource TextPrimaryBrush}" />
                                                    <Setter TargetName="Label" Property="FontWeight" Value="SemiBold" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsAddChip}" Value="True">
                                                    <Setter TargetName="AddGlyph" Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBox Style="{StaticResource InlineEditBox}" Width="110" FontSize="12" Padding="8,4"
                                         Text="{Binding EditText, UpdateSourceTrigger=PropertyChanged}"
                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVis}}"
                                         b:ViewBehaviors.FocusWhenVisible="True"
                                         b:ViewBehaviors.IsEditBox="True"
                                         KeyDown="ChipEdit_KeyDown" LostFocus="ChipEdit_LostFocus" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- 快速添加 -->
            <Grid Grid.Row="2" Margin="0,0,0,10">
                <TextBox x:Name="QuickAddBox" Style="{StaticResource GlassTextBox}"
                         Tag="添加任务，回车确认…"
                         Text="{Binding QuickAddText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="12,8,72,8" KeyDown="QuickAdd_KeyDown" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,8,0">
                    <Button Style="{StaticResource ComposeFlagStyle}" Content="&#xE7C1;" ToolTip="优先级"
                            Command="{Binding CycleComposePriorityCommand}" />
                    <Button Style="{StaticResource ComposeDueStyle}" Content="&#xE787;" ToolTip="日期与提醒"
                            Click="ComposeDue_Click" />
                </StackPanel>
            </Grid>

            <!-- 任务列表 -->
            <ScrollViewer Grid.Row="3" Style="{StaticResource GlassScroll}" PanningMode="VerticalOnly">
                <StackPanel Margin="0,0,2,0">
                    <StackPanel Margin="0,32,0,24"
                                Visibility="{Binding Pending.Count, Converter={StaticResource ZeroToVisible}}">
                        <TextBlock Text="&#xE73E;" Style="{StaticResource GlyphText}" FontSize="26" Opacity="0.45" />
                        <TextBlock Text="今日无事，静享清闲" Style="{StaticResource EmptyStateText}" Margin="0,12,0,0" />
                    </StackPanel>

                    <ItemsControl x:Name="PendingList" ItemsSource="{Binding Pending}"
                                  ItemTemplate="{StaticResource TaskRowTemplate}"
                                  b:DragReorderBehavior.IsEnabled="{Binding CanReorder}"
                                  b:DragReorderBehavior.CommitCommand="{Binding CommitReorderCommand}" />

                    <Expander Style="{StaticResource GlassExpander}" Margin="0,8,0,0" IsExpanded="False"
                              Visibility="{Binding Completed.Count, Converter={StaticResource NonZeroToVisible}}">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource SectionHeaderText}" Text="已完成" />
                                <TextBlock Style="{StaticResource SectionHeaderText}" Margin="6,0,0,0"
                                           Text="{Binding Completed.Count, Mode=OneWay}" />
                            </StackPanel>
                        </Expander.Header>
                        <StackPanel>
                            <Button Style="{StaticResource LinkButton}" Content="清空已完成"
                                    HorizontalAlignment="Right" Margin="0,2,4,2"
                                    Command="{Binding ClearCompletedCommand}" />
                            <ItemsControl ItemsSource="{Binding Completed}"
                                          ItemTemplate="{StaticResource TaskRowTemplate}" />
                        </StackPanel>
                    </Expander>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- 设置页（与主内容互斥切换） -->
        <Grid x:Name="SettingsHost" Margin="14,12,14,14"
              RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform X="0" />
            </Grid.RenderTransform>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                            <DataTrigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                         From="0" To="1" Duration="0:0:0.18" />
                                        <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                                         From="24" To="0" Duration="0:0:0.2">
                                            <DoubleAnimation.EasingFunction>
                                                <QuadraticEase EasingMode="EaseOut" />
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </DataTrigger.EnterActions>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <views:SettingsPanel />
        </Grid>

        <!-- 日期与提醒弹层（共享，PlacementTarget 由代码设置） -->
        <Popup x:Name="DuePopup" AllowsTransparency="True" StaysOpen="False" Placement="Bottom"
               PopupAnimation="Fade" IsOpen="{Binding DuePicker.IsOpen, Mode=TwoWay}"
               Opened="DuePopup_Opened" Closed="DuePopup_Closed">
            <Border x:Name="DuePopupPanel" Style="{StaticResource PopupPanel}" Width="272"
                    RenderTransformOrigin="0.5,0.08">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="DuePopupScale" />
                </Border.RenderTransform>
                <StackPanel DataContext="{Binding DuePicker}">

                    <!-- 状态行 + 清除 -->
                    <Grid Margin="2,0,2,8">
                        <TextBlock Text="{Binding CurrentText}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextSecondaryBrush}" />
                        <Button Style="{StaticResource LinkButton}" Content="清除" HorizontalAlignment="Right"
                                Visibility="{Binding HasDue, Converter={StaticResource BoolToVis}}"
                                Command="{Binding ClearDueCommand}" />
                    </Grid>

                    <!-- 快捷日期 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Content="今天" Command="{Binding SetQuickCommand}" CommandParameter="0">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTodayQuick}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="明天" Command="{Binding SetQuickCommand}" CommandParameter="1">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTomorrowQuick}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="下周一" Command="{Binding SetQuickCommand}" CommandParameter="monday">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMondayQuick}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- 月份导航 -->
                    <Grid Margin="2,4,0,0">
                        <TextBlock Text="{Binding MonthTitle}" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SmallIconButton}" Content="&#xE76B;"
                                    ToolTip="上个月" Command="{Binding PrevMonthCommand}" />
                            <Button Style="{StaticResource SmallIconButton}" Content="&#xE76C;"
                                    ToolTip="下个月" Command="{Binding NextMonthCommand}" />
                        </StackPanel>
                    </Grid>

                    <!-- 星期表头（周一开始） -->
                    <UniformGrid Columns="7" Margin="0,4,0,2">
                        <TextBlock Text="一" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="二" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="三" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="四" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="五" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="六" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                        <TextBlock Text="日" FontSize="10.5" HorizontalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" />
                    </UniformGrid>

                    <!-- 日历格 -->
                    <ItemsControl ItemsSource="{Binding Days}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="7" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:CalendarDayViewModel}">
                                <Button Height="30" Margin="1" Cursor="Hand" FocusVisualStyle="{x:Null}"
                                        Command="{Binding DataContext.SelectDayCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Grid Background="Transparent">
                                                <Border x:Name="Bg" Width="28" Height="28" CornerRadius="14"
                                                        Background="Transparent" BorderThickness="1"
                                                        BorderBrush="Transparent" />
                                                <TextBlock x:Name="Num" Text="{Binding Label}" FontSize="11.5"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                            </Grid>
                                            <ControlTemplate.Triggers>
                                                <DataTrigger Binding="{Binding InMonth}" Value="False">
                                                    <Setter TargetName="Num" Property="Opacity" Value="0.35" />
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource CardFillHoverBrush}" />
                                                </Trigger>
                                                <DataTrigger Binding="{Binding IsToday}" Value="True">
                                                    <Setter TargetName="Bg" Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                    <Setter TargetName="Bg" Property="Background" Value="{DynamicResource AccentBrush}" />
                                                    <Setter TargetName="Num" Property="Foreground" Value="{DynamicResource TextOnAccentBrush}" />
                                                    <Setter TargetName="Num" Property="FontWeight" Value="SemiBold" />
                                                    <Setter TargetName="Num" Property="Opacity" Value="1" />
                                                </DataTrigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Border Style="{StaticResource GlassDivider}" />

                    <!-- 提醒：开关 + 任意时间输入 -->
                    <Grid>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE823;" Style="{StaticResource GlyphText}" FontSize="12"
                                       Margin="2,0,6,0" />
                            <TextBlock Text="提醒" FontSize="13" VerticalAlignment="Center" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBox x:Name="TimeBox" Width="58" Style="{StaticResource InlineEditBox}"
                                     FontSize="12" Padding="6,3" TextAlignment="Center" MaxLength="5"
                                     b:ViewBehaviors.IsEditBox="True"
                                     ToolTip="输入任意时间，如 8:30 或 2145，回车确认"
                                     Text="{Binding EditTimeText, UpdateSourceTrigger=PropertyChanged}"
                                     KeyDown="TimeBox_KeyDown" LostFocus="TimeBox_LostFocus"
                                     Margin="0,0,10,0" />
                            <ToggleButton Style="{StaticResource GlassToggleSwitch}" VerticalAlignment="Center"
                                          IsChecked="{Binding ReminderOn, Mode=TwoWay}" />
                        </StackPanel>
                    </Grid>

                    <!-- 常用时间 -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="09:00" Command="{Binding SetTimeCommand}" CommandParameter="09:00">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ReminderOn}" Value="True" />
                                                <Condition Binding="{Binding SelectedTime}" Value="09:00" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="12:00" Command="{Binding SetTimeCommand}" CommandParameter="12:00">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ReminderOn}" Value="True" />
                                                <Condition Binding="{Binding SelectedTime}" Value="12:00" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="18:00" Command="{Binding SetTimeCommand}" CommandParameter="18:00">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ReminderOn}" Value="True" />
                                                <Condition Binding="{Binding SelectedTime}" Value="18:00" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="21:00" Command="{Binding SetTimeCommand}" CommandParameter="21:00">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource PickerChipButton}">
                                    <Style.Triggers>
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding ReminderOn}" Value="True" />
                                                <Condition Binding="{Binding SelectedTime}" Value="21:00" />
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Background" Value="{DynamicResource AccentDimBrush}" />
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>
