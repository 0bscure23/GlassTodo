<Window x:Class="GlassTodo.Views.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="提醒" Width="344" Height="118"
        WindowStyle="None" ResizeMode="NoResize" ShowInTaskbar="False" ShowActivated="False"
        Topmost="True" Background="Transparent"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        FontFamily="{StaticResource AppFont}"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="0"
                      ResizeBorderThickness="0" UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Grid>
        <Border Background="{DynamicResource GlassTintBrush}" />
        <Border Background="{DynamicResource SpecularBrush}" IsHitTestVisible="False" />
        <Border BorderBrush="{DynamicResource WindowInnerStrokeBrush}" BorderThickness="1"
                CornerRadius="8" IsHitTestVisible="False" />

        <Grid Margin="14,12,10,12" Background="Transparent" MouseLeftButtonUp="Body_Click">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border x:Name="PriorityBar" Width="3" CornerRadius="2" Margin="0,2,10,2"
                    Background="{DynamicResource AccentBrush}" />

            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" FontSize="14" FontWeight="SemiBold"
                           TextWrapping="Wrap" MaxHeight="42" TextTrimming="CharacterEllipsis" />
                <TextBlock x:Name="SubtitleText" FontSize="11.5" Margin="0,3,0,0"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel x:Name="ActionsRow" Orientation="Horizontal" Margin="0,10,0,2">
                    <Button Style="{StaticResource PrimaryButton}" Content="完成" Click="Done_Click" />
                    <Button Style="{StaticResource SubtleButton}" Content="稍后 10 分钟" Margin="8,0,0,0"
                            Click="Snooze_Click" />
                </StackPanel>
            </StackPanel>

            <Button Grid.Column="2" Style="{StaticResource SmallIconButton}" Content="&#xE711;"
                    VerticalAlignment="Top" Margin="6,0,0,0" Click="Close_Click" />
        </Grid>

        <!-- 自动关闭进度条（悬停暂停） -->
        <Border x:Name="Progress" Height="2" VerticalAlignment="Bottom" Margin="10,0,10,3"
                CornerRadius="1" Background="{DynamicResource AccentBrush}" Opacity="0.55"
                RenderTransformOrigin="0,0.5">
            <Border.RenderTransform>
                <ScaleTransform x:Name="ProgressScale" ScaleX="1" />
            </Border.RenderTransform>
        </Border>
    </Grid>
</Window>
