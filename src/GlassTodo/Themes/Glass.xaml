<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== 共享玻璃样式（与主题无关的结构性样式，颜色一律 DynamicResource） ===== -->

    <FontFamily x:Key="AppFont">Segoe UI Variable Display, Segoe UI, Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="FluentIcons">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- 字形图标 -->
    <Style x:Key="GlyphText" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentIcons}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- 弹出面板（右键菜单 / 日期选择等）：近实色玻璃 + 圆角 + 投影 -->
    <Style x:Key="PopupPanel" TargetType="Border">
        <Setter Property="Background" Value="{DynamicResource MenuFillBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MenuStrokeBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="Margin" Value="12" />
        <Setter Property="Effect">
            <Setter.Value>
                <DropShadowEffect BlurRadius="24" ShadowDepth="6" Direction="270" Opacity="0.35" Color="#000000" />
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 分区小标题（如「已完成」） -->
    <Style x:Key="SectionHeaderText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>

    <!-- 空状态 -->
    <Style x:Key="EmptyStateText" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <!-- 分隔线 -->
    <Style x:Key="GlassDivider" TargetType="Border">
        <Setter Property="Height" Value="1" />
        <Setter Property="Background" Value="{DynamicResource DividerBrush}" />
        <Setter Property="Margin" Value="0,8" />
    </Style>

</ResourceDictionary>
