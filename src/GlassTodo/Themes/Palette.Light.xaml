<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:po="http://schemas.microsoft.com/winfx/2006/xaml/presentation/options"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="po">

    <!-- ===== 琉璃清单 · 浅色玻璃调色板 ===== -->

    <SolidColorBrush x:Key="GlassTintBrush" Color="#4DF6F8FC" po:Freeze="True" />
    <SolidColorBrush x:Key="GlassTintLiquidBrush" Color="#4DFFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="GlassFallbackSolidBrush" Color="#F2F4F6FA" po:Freeze="True" />

    <LinearGradientBrush x:Key="SpecularBrush" StartPoint="0,0" EndPoint="0,1" po:Freeze="True">
        <GradientStop Color="#73FFFFFF" Offset="0" />
        <GradientStop Color="#1FFFFFFF" Offset="0.14" />
        <GradientStop Color="#00FFFFFF" Offset="0.24" />
    </LinearGradientBrush>

    <SolidColorBrush x:Key="HairlineTopBrush" Color="#CCFFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="WindowInnerStrokeBrush" Color="#66FFFFFF" po:Freeze="True" />

    <SolidColorBrush x:Key="CardFillBrush" Color="#8CFFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="CardFillHoverBrush" Color="#BFFFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="CardFillPressedBrush" Color="#D9FFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="CardStrokeBrush" Color="#14000000" po:Freeze="True" />

    <SolidColorBrush x:Key="InputFillBrush" Color="#73FFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="InputStrokeBrush" Color="#1A000000" po:Freeze="True" />
    <SolidColorBrush x:Key="InputFocusStrokeBrush" Color="#802E6BE6" po:Freeze="True" />

    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E51B1B20" po:Freeze="True" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8C3C3C43" po:Freeze="True" />
    <SolidColorBrush x:Key="TextDoneBrush" Color="#663C3C43" po:Freeze="True" />
    <SolidColorBrush x:Key="TextOnAccentBrush" Color="#FFFFFFFF" po:Freeze="True" />

    <SolidColorBrush x:Key="AccentBrush" Color="#2E6BE6" po:Freeze="True" />
    <SolidColorBrush x:Key="AccentDimBrush" Color="#262E6BE6" po:Freeze="True" />

    <SolidColorBrush x:Key="PriorityHighBrush" Color="#E5484D" po:Freeze="True" />
    <SolidColorBrush x:Key="PriorityMediumBrush" Color="#E79008" po:Freeze="True" />
    <SolidColorBrush x:Key="PriorityLowBrush" Color="#2F9E68" po:Freeze="True" />
    <SolidColorBrush x:Key="DangerBrush" Color="#E5484D" po:Freeze="True" />

    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#40000000" po:Freeze="True" />
    <SolidColorBrush x:Key="DividerBrush" Color="#14000000" po:Freeze="True" />
    <SolidColorBrush x:Key="CheckRingBrush" Color="#593C3C43" po:Freeze="True" />
    <SolidColorBrush x:Key="ToggleKnobBrush" Color="#FFFFFFFF" po:Freeze="True" />

    <SolidColorBrush x:Key="MenuFillBrush" Color="#F2FFFFFF" po:Freeze="True" />
    <SolidColorBrush x:Key="MenuStrokeBrush" Color="#14000000" po:Freeze="True" />

    <!-- 液态玻璃：光斑 / 高光扫过 / 棱边 -->
    <Color x:Key="LiquidLightColor">#59FFFFFF</Color>
    <Color x:Key="LiquidGlintColor">#8CFFFFFF</Color>
    <Color x:Key="LiquidSheenColor">#80FFFFFF</Color>
    <LinearGradientBrush x:Key="LiquidRimBrush" StartPoint="0,0" EndPoint="1,1" po:Freeze="True">
        <GradientStop Color="#F2FFFFFF" Offset="0" />
        <GradientStop Color="#4DFFFFFF" Offset="0.35" />
        <GradientStop Color="#26FFFFFF" Offset="0.7" />
        <GradientStop Color="#A6FFFFFF" Offset="1" />
    </LinearGradientBrush>

</ResourceDictionary>
